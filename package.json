{
  "name": "ecommerce-root",
  "version": "1.0.0",
  "description": "MERN Stack E-Commerce Website Root Workspace",
  "private": true,
  "scripts": {
    "postinstall": "npm run install-backend && npm run install-frontend",
    "install-backend": "npm install --prefix backend",
    "install-frontend": "npm install --prefix frontend --legacy-peer-deps",
    "seed": "npm run seed --prefix backend",
    "dev-backend": "npm run dev --prefix backend",
    "dev-frontend": "npm run dev --prefix frontend",
    "dev": "concurrently --kill-others-on-fail \"npm:dev-backend\" \"npm:dev-frontend\"",
    "build-frontend": "npm run build --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
